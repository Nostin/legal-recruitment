# PostgreSQL connection string (SQLAlchemy + psycopg v3)
# Local (see ARCHITECTURE.md):
# DATABASE_URL=postgresql+psycopg://seanthompson@localhost:5432/legal
#
# Plain postgresql://... is also accepted; the app rewrites it to use the psycopg v3 driver.
#
# Neon later: swap only this value, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://seanthompson@localhost:5432/legal
